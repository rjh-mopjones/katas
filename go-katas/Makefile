# Go katas — run from go-katas/. Two modules: solution/ (answer key, GREEN) and practice/ (yours).
# Most of the time you only care about the practice targets while solving.

.PHONY: test test-race vet build practice practice-race practice-vet solution solution-race tidy

## --- practice (the module you implement) ---
practice:            ## go test ./... in practice
	cd practice && go test ./...

practice-race:       ## go test -race ./... in practice (concurrency bugs surface here)
	cd practice && go test -race ./...

practice-vet:        ## go vet ./... in practice
	cd practice && go vet ./...

## --- solution (reference answer key — always green) ---
solution:
	cd solution && go test ./...

solution-race:
	cd solution && go test -race ./...

## --- everything ---
build:
	cd solution && go build ./...
	cd practice && go build ./...

vet:
	cd solution && go vet ./...
	cd practice && go vet ./...

test:
	cd solution && go test ./...
	cd practice && go test ./...

test-race:
	cd solution && go test -race ./...
	cd practice && go test -race ./...

tidy:
	cd solution && go mod tidy
	cd practice && go mod tidy
